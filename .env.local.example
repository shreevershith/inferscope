# ──────────────────────────────────────────────────────────────────────────
# InferScope environment template
# ──────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local (gitignored) and fill in your real values.
#
#   cp .env.local.example .env.local
#
# .env.local is the conventional Vite file for machine-specific env vars.
# It's gitignored by the `*.local` pattern, so your real keys never leave
# your machine. Vite's load precedence puts .env.local ahead of .env and
# baked-in defaults, so values here override everything else at runtime.
# ──────────────────────────────────────────────────────────────────────────


# Groq API key — powers the AI Advisor panel (Llama 3.3 70B).
# Get a free key at https://console.groq.com
# REQUIRED — without this, the Advisor returns an error.
GROQ_API_KEY=your_groq_api_key_here


# Google Analytics 4 measurement ID — tracks page views and engagement events.
# Format: G-XXXXXXXXXX. Get one at https://analytics.google.com
# OPTIONAL — leave unset (or as placeholder) to disable analytics entirely.
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX


# CORS allow-list for the serverless API endpoints (production only).
# OPTIONAL — when set, /api/ai-chat returns Access-Control-Allow-Origin
# only for this domain. Useful in production to prevent your Groq quota
# from being burned by other sites' browser requests.
# Example: ALLOWED_ORIGIN=https://inferscope.vercel.app
ALLOWED_ORIGIN=


# ──────────────────────────────────────────────────────────────────────────
# No keys required for the live data feeds:
#   • OpenRouter catalog          (public /api/v1/models)
#   • Arena leaderboards          (public wulong.dev proxy)
#   • Vast.ai GPU bundles         (public, fetched via /api/gpu-pricing)
# All three are called server-side or with no auth; no env vars needed.
# ──────────────────────────────────────────────────────────────────────────
