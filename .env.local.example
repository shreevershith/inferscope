# ──────────────────────────────────────────────────────────────────────────
# InferScope environment template
# ──────────────────────────────────────────────────────────────────────────
# Copy this file to .env (which is gitignored) and fill in your real values.
#
#   cp .env.local.example .env
#
# Vite's env load precedence is:
#   .env.local  >  .env  >  baked defaults
# .env.local itself is gitignored, so if you want local overrides that
# never leave your machine, you can create one. Otherwise just use .env.
# ──────────────────────────────────────────────────────────────────────────


# Groq API key — powers the AI Advisor panel (Llama 3.3 70B)
# Get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here


# Google Analytics 4 measurement ID — tracks page views and engagement events
# Format: G-XXXXXXXXXX. Get one at https://analytics.google.com
# Leave unset (or as placeholder) to disable analytics entirely.
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
